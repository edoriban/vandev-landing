---
import LegalLayout from "@layouts/LegalLayout.astro";
import { useTranslations } from "@i18n/utils";

const lang = "es";
const t = useTranslations(lang);
const siteUrl = "https://vandev.mx";

const faqs = [
	{
		question: "¿Qué servicios ofrece VanDev?",
		answer: "Ofrecemos desarrollo web (React, Next.js, Astro), aplicaciones de escritorio (Tauri + Rust), plataformas SaaS, soluciones de IA industrial (visión artificial, detección de anomalías) y consultoría tecnológica.",
	},
	{
		question: "¿Qué tecnologías utilizan?",
		answer: "Nuestro stack principal incluye React, Next.js, Astro y Tailwind para frontend; Rust y Tauri para desktop; Python, YOLO y EfficientAD para IA; y Node.js, Django y PostgreSQL para backend.",
	},
	{
		question: "¿Cómo es el proceso de un proyecto?",
		answer: "Iniciamos con una consulta gratuita para entender tus necesidades. Luego definimos alcance y presupuesto, seguido de desarrollo ágil con entregas incrementales semanales. Ves progreso real desde la primera semana.",
	},
	{
		question: "¿Cuál es el modelo de precios?",
		answer: "Trabajamos con presupuestos por proyecto y también ofrecemos contratos por horas. Cada propuesta se adapta a las necesidades y presupuesto del cliente. La consulta inicial es sin costo.",
	},
	{
		question: "¿Cuánto tiempo toma un proyecto típico?",
		answer: "Depende del alcance: un sitio web puede estar listo en 2-4 semanas, una aplicación web en 1-3 meses, y soluciones empresariales o de IA pueden tomar 3-6 meses. Siempre proporcionamos un cronograma detallado antes de iniciar.",
	},
	{
		question: "¿Ofrecen soporte después del lanzamiento?",
		answer: "Sí. Ofrecemos planes de mantenimiento y soporte continuo. Esto incluye corrección de bugs, actualizaciones de seguridad, optimización de rendimiento y nuevas funcionalidades según se necesiten.",
	},
	{
		question: "¿Trabajan con clientes fuera de México?",
		answer: "Sí, trabajamos con clientes de cualquier parte del mundo. La comunicación se realiza en español o inglés, y nos adaptamos a diferentes zonas horarias.",
	},
	{
		question: "¿Cómo puedo contactarlos?",
		answer: "Envíanos un correo a edoriban@gmail.com o encuéntranos en GitHub y LinkedIn. Respondemos en menos de 24 horas.",
	},
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
};
---

<LegalLayout
	title={t("legal.faq.title")}
	lang={lang}
	description="Preguntas frecuentes sobre VanDev. Servicios, tecnologías, proceso de trabajo, precios, tiempos de entrega y soporte."
	canonicalUrl={`${siteUrl}/es/faq`}
	alternateUrl={`${siteUrl}/en/faq`}
	jsonLd={faqSchema}
>
	<div class="faq-list space-y-3">
		{faqs.map((faq, i) => (
			<details class="faq-item group border border-lime-500/20 bg-black/40">
				<summary class="flex items-center gap-3 cursor-pointer p-4 hover:bg-lime-400/5 transition-colors select-none">
					<span class="faq-chevron text-lime-400 text-xs font-mono transition-transform duration-200 group-open:rotate-90">&#9654;</span>
					<h3 class="text-gray-200 font-mono text-sm font-medium m-0">
						<span class="text-lime-400/60 mr-2">[{String(i).padStart(2, "0")}]</span>
						{faq.question}
					</h3>
				</summary>
				<div class="px-4 pb-4 pl-10">
					<p class="text-gray-400 font-mono text-sm leading-relaxed">{faq.answer}</p>
				</div>
			</details>
		))}
	</div>
</LegalLayout>

<style>
	details > summary::-webkit-details-marker {
		display: none;
	}

	details > summary {
		list-style: none;
	}

	.faq-item :global(h3) {
		font-size: 0.875rem;
		font-weight: 500;
		color: #e5e7eb;
		text-transform: none;
		letter-spacing: normal;
		margin: 0;
	}
</style>
