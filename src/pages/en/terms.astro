---
import LegalLayout from "@layouts/LegalLayout.astro";
import { useTranslations } from "@i18n/utils";

const lang = "en";
const t = useTranslations(lang);
const siteUrl = "https://vandev.mx";
---

<LegalLayout
	title={t("legal.terms.title")}
	lang={lang}
	description="VanDev Terms & Conditions. Intellectual property, acceptable use, and limitation of liability for vandev.mx."
