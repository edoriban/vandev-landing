---
const year = new Date().getFullYear();
---

<footer
    class="footer-section border-t border-lime-500/20 bg-surface/90 backdrop-blur-sm mt-16"
>
    <div class="max-w-6xl mx-auto px-4 py-8">
        <!-- Main Footer Grid -->
        <div class="footer-grid grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <!-- Brand Column -->
            <div class="brand-col">
                <div
                    class="logo-frame relative inline-block px-3 py-1.5 border border-lime-500/40 bg-black/60"
                >
                    <!-- Mini Corner Brackets -->
                    <div class="absolute -top-[1px] -left-[1px] w-2 h-2 border-t border-l border-lime-400"></div>
                    <div class="absolute -top-[1px] -right-[1px] w-2 h-2 border-t border-r border-lime-400"></div>
                    <div class="absolute -bottom-[1px] -left-[1px] w-2 h-2 border-b border-l border-lime-400"></div>
                    <div class="absolute -bottom-[1px] -right-[1px] w-2 h-2 border-b border-r border-lime-400"></div>

                    <div class="flex items-center gap-2">
                        <span class="text-lime-400 font-mono text-xs opacity-60">&gt;_</span>
                        <span class="font-mono font-bold text-sm tracking-wider text-white uppercase">
                            VAN<span class="text-lime-400">.DEV</span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Links Column -->
            <div class="links-col font-mono text-xs">
                <div class="text-gray-500 mb-3">NAVIGATION</div>
                <div class="flex flex-wrap gap-4">
                    <a
                        href="#hero-section"
                        class="text-gray-400 hover:text-lime-400 transition-colors"
                        >&gt; HOME</a
                    >
                    <a
                        href="#about"
                        class="text-gray-400 hover:text-lime-400 transition-colors"
                        >&gt; ABOUT</a
                    >
                    <a
                        href="#projects"
                        class="text-gray-400 hover:text-lime-400 transition-colors"
                        >&gt; PROJECTS</a
                    >
                    <a
                        href="#contact"
                        class="text-gray-400 hover:text-lime-400 transition-colors"
                        >&gt; CONTACT</a
                    >
                </div>
            </div>

            <!-- Social Column -->
            <div class="social-col text-right">
                <div class="text-gray-500 font-mono text-xs mb-3">CONNECT</div>
                <div class="flex gap-3 justify-end">
                    <a
                        href="https://github.com/edoriban"
                        target="_blank"
                        rel="noopener"
                        aria-label="GitHub"
                        class="social-link w-10 h-10 flex items-center justify-center border border-lime-500/30 text-gray-400 hover:text-lime-400 hover:border-lime-400/60 hover:bg-lime-400/10 transition-all duration-300"
                    >
                        <svg
                            width="18"
                            height="18"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.207 11.387.6.113.793-.26.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.744.084-.729.084-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.236 1.911 1.236 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.824 1.102.824 2.222v3.293c0 .319.192.694.801.576C20.565 21.796 24 17.299 24 12c0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://www.linkedin.com/in/edoriban"
                        target="_blank"
                        rel="noopener"
                        aria-label="LinkedIn"
                        class="social-link w-10 h-10 flex items-center justify-center border border-lime-500/30 text-gray-400 hover:text-lime-400 hover:border-lime-400/60 hover:bg-lime-400/10 transition-all duration-300"
                    >
                        <svg
                            width="18"
                            height="18"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="mailto:edoriban@gmail.com"
                        aria-label="Email"
                        class="social-link w-10 h-10 flex items-center justify-center border border-lime-500/30 text-gray-400 hover:text-lime-400 hover:border-lime-400/60 hover:bg-lime-400/10 transition-all duration-300"
                    >
                        <svg
                            width="18"
                            height="18"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 13.065l-11.99-8.065h23.98l-11.99 8.065zm-12-7.065v14h24v-14l-12 8.065-12-8.065z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div
            class="footer-bottom border-t border-lime-500/10 pt-6 flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <div class="font-mono text-xs text-gray-600 flex items-center gap-2">
                <span class="text-lime-400/40">&gt;</span> MX-NL // RUST · REACT · PYTHON // SHIPPING SINCE 2018
            </div>
            <div
                class="font-mono text-xs text-gray-600 flex items-center gap-2"
            >
                <span class="w-2 h-2 bg-lime-400 rounded-full animate-pulse"
                ></span>
                BUILT WITH ASTRO + TAILWIND
            </div>
        </div>
    </div>
</footer>

<style>
    .social-link {
        clip-path: polygon(
            0 4px,
            4px 0,
            100% 0,
            100% calc(100% - 4px),
            calc(100% - 4px) 100%,
            0 100%
        );
    }
</style>
