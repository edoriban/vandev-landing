---
// Skills data organized by category
const skills = [
    {
        category: "FRONTEND",
        items: ["React.js", "JavaScript", "TypeScript", "HTML5", "CSS3", "Tailwind CSS", "Astro", "Next.js"],
    },
    {
        category: "BACKEND",
        items: ["Node.js", "ASP.NET", "C#", "Python", "GraphQL", "REST APIs", "WebSockets", "Entity Framework"],
    },
    {
        category: "DATABASES",
        items: ["PostgreSQL", "MongoDB", "SQL Server", "Redis", "SQLite"],
    },
    {
        category: "DEVOPS",
        items: ["Git", "Docker", "GitHub Actions", "Vercel", "Linux"],
    },
    {
        category: "SOFT_SKILLS",
        items: ["Problem Solving", "Team Leadership", "Agile", "Communication"],
    },
];

// Flatten for marquee
const allSkills = skills.flatMap(s => s.items);
const marqueeSkills = [...allSkills, ...allSkills];
---

<section id="skills" class="skills-section ">
    <div class="container mx-auto px-4 max-w-6xl">
        
        <!-- Section Header with Device Frame -->
        <div class="skills-header mb-12">
            <div class="header-device-frame relative border border-lime-500/30 bg-black/60 p-8 max-w-xl">
                <!-- Corner Brackets -->
                <div class="corner-tl absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-lime-400"></div>
                <div class="corner-tr absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-lime-400"></div>
                <div class="corner-bl absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-lime-400"></div>
                <div class="corner-br absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-lime-400"></div>
                
                <div class="skills-header-tag font-mono text-xs text-lime-400 tracking-widest mb-4">
                    // SKILLS.CONFIG
                </div>
                <h2 class="section-title text-5xl md:text-6xl lg:text-7xl font-black text-white leading-none">
                    TECH<br/>
                    <span class="text-lime-400">STACK_</span>
                </h2>
                <div class="header-status font-mono text-xs text-gray-500 mt-4 flex items-center gap-4">
                    <span class="flex items-center gap-2">
                        <span class="status-dot w-2 h-2 bg-lime-400 rounded-full animate-pulse"></span>
                        SKILLS.READY
                    </span>
                    <span class="text-lime-500/50">|</span>
                    <span>COUNT: {skills.reduce((acc, cat) => acc + cat.items.length, 0)}</span>
                </div>
            </div>
        </div>

        <!-- Skills Grid - Terminal Style -->
        <div class="skills-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
            {skills.map((category, catIndex) => (
                <div class={`skill-category category-${catIndex}`}>
                    <div class="category-frame relative p-4 border border-lime-500/20 bg-black/40 hover:border-lime-400/50 transition-all duration-300">
                        <!-- Corner Accents -->
                        <div class="corner-tl absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2 border-lime-400"></div>
                        <div class="corner-br absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2 border-lime-400"></div>
                        
                        <!-- Category Header -->
                        <div class="category-header font-mono text-xs text-lime-400 mb-3 flex items-center gap-2">
                            <span class="w-2 h-2 bg-lime-400 animate-pulse"></span>
                            {category.category}
                        </div>
                        
                        <!-- Skills List -->
                        <div class="skills-list flex flex-wrap gap-2">
                            {category.items.map(skill => (
                                <span class="skill-item px-2 py-1 text-xs font-mono bg-lime-500/10 text-gray-300 border border-lime-500/30 hover:bg-lime-400/20 hover:text-lime-300 hover:border-lime-400/50 transition-all duration-200 cursor-default">
                                    {skill}
                                </span>
                            ))}
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- Marquee Skills Runner -->
        <div class="marquee-container relative overflow-hidden py-4 border-y border-lime-500/20">
            <!-- Gradient Masks -->
            <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-surface to-transparent z-10"></div>
            <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-surface to-transparent z-10"></div>
            
            <div class="marquee-track flex gap-8">
                {marqueeSkills.map(skill => (
                    <span class="marquee-item font-mono text-sm text-gray-500 whitespace-nowrap hover:text-lime-400 transition-colors">
                        {skill}
                    </span>
                ))}
            </div>
        </div>

        <!-- Stats Row -->
        <div class="skills-stats flex justify-center gap-12 mt-6 font-mono text-center">
            <div class="stat-item">
                <span class="block text-2xl font-bold text-lime-400">{allSkills.length}+</span>
                <span class="text-xs text-gray-500">TECHNOLOGIES</span>
            </div>
            <div class="stat-item">
                <span class="block text-2xl font-bold text-white">{skills.length}</span>
                <span class="text-xs text-gray-500">CATEGORIES</span>
            </div>
            <div class="stat-item">
                <span class="block text-2xl font-bold text-lime-400">∞</span>
                <span class="text-xs text-gray-500">LEARNING</span>
            </div>
        </div>
    </div>
</section>

<style>
    /* Skills Section */
    .skills-section {
        position: relative;
    }

    /* Category Cards - visible by default */
    .skill-category {
        opacity: 1;
        transform: none;
    }

    .category-frame:hover {
        box-shadow: 0 0 30px rgba(191, 255, 0, 0.1);
    }

    .category-frame:hover .corner-tl,
    .category-frame:hover .corner-br {
        width: 16px;
        height: 16px;
    }

    .corner-tl, .corner-br {
        transition: all 0.3s ease;
    }

    /* Marquee Animation */
    .marquee-track {
        animation: marquee 30s linear infinite;
    }

    @keyframes marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .marquee-container:hover .marquee-track {
        animation-play-state: paused;
    }

    /* Skill Items */
    .skill-item {
        position: relative;
    }

    .skill-item::before {
        content: '>';
        margin-right: 4px;
        color: rgba(191, 255, 0, 0.5);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // Skills Header - animate the device frame and its contents
        const skillsHeader = document.querySelector("#skills .header-device-frame");
        const skillsHeaderTag = document.querySelector("#skills .skills-header-tag");
        const skillsSectionTitle = document.querySelector("#skills .section-title");
        const skillsHeaderStatus = document.querySelector("#skills .header-status");
        
        if (skillsHeader) {
            gsap.set(skillsHeader, { opacity: 0, x: -50 });
            gsap.to(skillsHeader, {
                scrollTrigger: {
                    trigger: "#skills",
                    start: "top 85%",
                    toggleActions: "play none none none"
                },
                opacity: 1,
                x: 0,
                duration: 0.6,
                ease: "power3.out"
            });
        }
        
        if (skillsHeaderTag) {
            gsap.set(skillsHeaderTag, { opacity: 0, x: -30 });
            gsap.to(skillsHeaderTag, {
                scrollTrigger: {
                    trigger: "#skills",
                    start: "top 85%",
                    toggleActions: "play none none none"
                },
                opacity: 1,
                x: 0,
                duration: 0.5,
                delay: 0.2
            });
        }
        
        if (skillsSectionTitle) {
            gsap.set(skillsSectionTitle, { opacity: 0, y: 40 });
            gsap.to(skillsSectionTitle, {
                scrollTrigger: {
                    trigger: "#skills",
                    start: "top 85%",
                    toggleActions: "play none none none"
                },
                opacity: 1,
                y: 0,
                duration: 0.8,
                delay: 0.3
            });
        }
        
        if (skillsHeaderStatus) {
            gsap.set(skillsHeaderStatus, { opacity: 0 });
            gsap.to(skillsHeaderStatus, {
                scrollTrigger: {
                    trigger: "#skills",
                    start: "top 85%",
                    toggleActions: "play none none none"
                },
                opacity: 1,
                duration: 0.5,
                delay: 0.5
            });
        }

        // Category Cards
        const categories = document.querySelectorAll(".skill-category");
        categories.forEach((cat, index) => {
            gsap.set(cat, { opacity: 0, y: 30 });
            gsap.to(cat, {
                scrollTrigger: {
                    trigger: cat,
                    start: "top 95%",
                    toggleActions: "play none none none"
                },
                opacity: 1,
                y: 0,
                duration: 0.5,
                delay: index * 0.08
            });
        });

        // Stats
        const statItems = document.querySelectorAll(".stat-item");
        statItems.forEach((stat, index) => {
            gsap.set(stat, { opacity: 0, y: 20 });
            gsap.to(stat, {
                scrollTrigger: {
                    trigger: ".skills-stats",
                    start: "top 95%",
                    toggleActions: "play none none none"
                },
                opacity: 1,
                y: 0,
                duration: 0.4,
                delay: index * 0.1
            });
        });
    });
</script>
