---
import Header from "@components/ui/Header.astro";
import Background from "@components/ui/Background.astro";
import ScrollAnimations from "@components/ui/ScrollAnimations.astro";
import ScrollProgressBar from "@components/ui/ScrollProgressBar.astro";
import MagneticEffect from "@components/ui/MagneticEffect.astro";
import TextScramble from "@components/ui/TextScramble.astro";
import CookieConsent from "@components/ui/CookieConsent.astro";
import "@styles/shared.css";
import "@fontsource-variable/onest";
import type { Lang } from "@i18n/ui";
import { getAlternateLang, getLocalizedPath } from "@i18n/utils";

interface Props {
	title: string;
	lang: Lang;
	description?: string;
	canonicalUrl?: string;
	alternateUrl?: string;
	jsonLd?: Record<string, unknown>;
}
const { title, lang, canonicalUrl, alternateUrl, jsonLd } = Astro.props;

const siteUrl = "https://vandev.mx";
const canonical = canonicalUrl || `${siteUrl}${getLocalizedPath(lang)}`;
const altLang = getAlternateLang(lang);
const altHref = alternateUrl || `${siteUrl}${getLocalizedPath(altLang)}`;

const description =
	Astro.props.description ||
	(lang === "es"
		? "VanDev — Desarrollo de software a la medida. Expertos en web, desktop, SaaS y soluciones industriales con IA."
		: "VanDev — Custom software development. Experts in web, desktop, SaaS, and industrial AI solutions.");

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	name: "VanDev",
	url: siteUrl,
	logo: `${siteUrl}/favicon.svg`,
	description: lang === "es"
		? "Desarrollo de software a la medida. Web, desktop, SaaS y soluciones industriales con IA."
		: "Custom software development. Web, desktop, SaaS, and industrial AI solutions.",
	address: {
		"@type": "PostalAddress",
		addressRegion: "Nuevo León",
		addressCountry: "MX",
	},
	contactPoint: {
		"@type": "ContactPoint",
		contactType: "General",
		email: "edoriban@gmail.com",
	},
	sameAs: [
		"https://github.com/edoriban",
		"https://www.linkedin.com/in/edoriban",
	],
	foundingDate: "2017",
};

const pageSchema = jsonLd || organizationSchema;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang={lang} href={canonical} />
		<link rel="alternate" hreflang={altLang} href={altHref} />
		<link rel="alternate" hreflang="x-default" href={`${siteUrl}/es`} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={`${siteUrl}/android-chrome-512x512.png`} />
		<meta property="og:image:width" content="512" />
		<meta property="og:image:height" content="512" />
		<meta property="og:locale" content={lang === "es" ? "es_MX" : "en_US"} />
		<meta property="og:site_name" content="VanDev" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteUrl}/android-chrome-512x512.png`} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
		<noscript><style>.page-wrapper { opacity: 1 !important; }</style></noscript>
	</head>
	<body>
		<ScrollProgressBar />
		<Background />
		<div class="page-wrapper">
			<Header lang={lang} />
			<slot />
		</div>
		<ScrollAnimations />
		<MagneticEffect />
		<TextScramble />
		<CookieConsent lang={lang} />
	</body>
</html>

<script>
	import { gsap } from "gsap";

	document.addEventListener("DOMContentLoaded", () => {
		gsap.fromTo(
			".page-wrapper",
			{ opacity: 0 },
			{ opacity: 1, duration: 0.8, ease: "power2.out" },
		);
	});
</script>

<style is:global>
	:root {
		color-scheme: light dark;
		--color-surface: #0a0a08;
		--color-surface-glass: rgba(10, 10, 8, 0.6);
		--color-accent: #bfff00;
		--color-accent-green: #22c55e;
	}

	html {
		font-family: "Onest Variable", system-ui, sans-serif;
		scroll-behavior: smooth;
	}

	body {
		background-color: var(--color-surface);
		position: relative;
		color: #e2e8f0;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		overflow-x: hidden;
	}

	.page-wrapper {
		opacity: 0; /* Para la animación de entrada */
		position: relative;
		z-index: 1;
	}
</style>
