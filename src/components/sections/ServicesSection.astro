---
import "@styles/shared.css";
import type { Lang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
    {
        id: "01",
        titleKey: "services.web.title" as const,
        descKey: "services.web.description" as const,
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
    },
    {
        id: "02",
        titleKey: "services.desktop.title" as const,
        descKey: "services.desktop.description" as const,
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    },
    {
        id: "03",
        titleKey: "services.saas.title" as const,
        descKey: "services.saas.description" as const,
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    },
    {
        id: "04",
        titleKey: "services.consulting.title" as const,
        descKey: "services.consulting.description" as const,
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    },
];
---

<section id="services" class="services-section py-24 relative scroll-mt-16">
    <div class="container mx-auto px-4 max-w-7xl">
        <!-- Section Header -->
        <div class="services-header mb-16">
            <div class="header-device-frame relative border border-lime-500/30 bg-black/60 p-8 max-w-2xl overflow-visible">
                <div class="absolute -top-[1px] -left-[1px] w-6 h-6 border-t-2 border-l-2 border-lime-400"></div>
                <div class="absolute -top-[1px] -right-[1px] w-6 h-6 border-t-2 border-r-2 border-lime-400"></div>
                <div class="absolute -bottom-[1px] -left-[1px] w-6 h-6 border-b-2 border-l-2 border-lime-400"></div>
                <div class="absolute -bottom-[1px] -right-[1px] w-6 h-6 border-b-2 border-r-2 border-lime-400"></div>

                <div class="header-tag font-mono text-xs text-lime-400 tracking-widest mb-4">
                    {t("services.tag")}
                </div>
                <h2 class="section-title text-5xl md:text-6xl lg:text-7xl font-black text-white leading-none">
                    {t("services.title.line1")}<br />
                    <span class="text-lime-400">{t("services.title.line2")}</span>
                </h2>
            </div>
        </div>

        <!-- Services Grid -->
        <div class="services-grid grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map((service, index) => (
                <article
                    class="service-card group relative"
                >
                    <!-- Corner Brackets -->
                    <div class="absolute -top-[1px] -left-[1px] w-5 h-5 border-t-2 border-l-2 border-lime-400/60 z-10 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>
                    <div class="absolute -top-[1px] -right-[1px] w-5 h-5 border-t-2 border-r-2 border-lime-400/60 z-10 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>
                    <div class="absolute -bottom-[1px] -left-[1px] w-5 h-5 border-b-2 border-l-2 border-lime-400/60 z-10 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>
                    <div class="absolute -bottom-[1px] -right-[1px] w-5 h-5 border-b-2 border-r-2 border-lime-400/60 z-10 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>

                    <div class="card-inner border border-lime-500/15 bg-black/80 transition-all duration-400 group-hover:border-lime-500/50 group-hover:shadow-[0_20px_40px_-20px_rgba(191,255,0,0.2)]">
                        <!-- Terminal Top Bar -->
                        <div class="flex items-center justify-between px-4 py-2 border-b border-lime-500/20 bg-black/80">
                            <div class="flex items-center gap-2 font-mono text-xs">
                                <span class="w-2 h-2 rounded-full bg-lime-400 animate-pulse"></span>
                                <span class="text-lime-400/70">SERVICE_{service.id}</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                                <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                                <div class="w-2 h-2 rounded-full bg-lime-400"></div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-6">
                            <div class="flex items-start gap-4">
                                <div class="service-icon text-lime-400 flex-shrink-0 opacity-80 group-hover:opacity-100 transition-opacity" set:html={service.icon} />
                                <div>
                                    <h3 class="text-lg font-black text-white font-mono uppercase tracking-wide group-hover:text-lime-400 transition-colors">
                                        {t(service.titleKey)}
                                    </h3>
                                    <p class="text-gray-400 text-sm font-mono mt-2 leading-relaxed">
                                        &gt; {t(service.descKey)}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // Header animation
        const headerFrame = document.querySelector("#services .header-device-frame");
        if (headerFrame) {
            gsap.set(headerFrame, { opacity: 0, x: -50 });
            gsap.to(headerFrame, {
                scrollTrigger: { trigger: "#services", start: "top 80%", toggleActions: "play none none none" },
                opacity: 1, x: 0, duration: 0.6, ease: "power3.out",
            });
        }

        // Service cards stagger
        const cards = document.querySelectorAll(".service-card");
        cards.forEach((card, index) => {
            gsap.set(card, { opacity: 0, y: 50, scale: 0.95 });
            gsap.to(card, {
                scrollTrigger: { trigger: card, start: "top 90%", toggleActions: "play none none none" },
                opacity: 1, y: 0, scale: 1, duration: 0.6, delay: index * 0.1, ease: "power3.out",
            });
        });

        // 3D tilt hover effect
        cards.forEach((item) => {
            const card = item.querySelector(".card-inner") as HTMLElement;
            if (!card) return;

            item.addEventListener("mousemove", (e: Event) => {
                const mouseEvent = e as MouseEvent;
                const rect = card.getBoundingClientRect();
                const x = mouseEvent.clientX - rect.left;
                const y = mouseEvent.clientY - rect.top;
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                const rotateX = ((y - centerY) / centerY) * -3;
                const rotateY = ((x - centerX) / centerX) * 3;

                gsap.to(card, {
                    rotateX, rotateY, scale: 1.02,
                    duration: 0.3, ease: "power2.out", transformPerspective: 1000,
                });
            });

            item.addEventListener("mouseleave", () => {
                gsap.to(card, { rotateX: 0, rotateY: 0, scale: 1, duration: 0.5, ease: "power3.out" });
            });
        });
    });
</script>
