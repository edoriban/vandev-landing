---
import "@styles/shared.css";
import type { Lang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const differentials = [
    { num: "01", titleKey: "why.tech.title" as const, descKey: "why.tech.description" as const },
    { num: "02", titleKey: "why.custom.title" as const, descKey: "why.custom.description" as const },
    { num: "03", titleKey: "why.industrial.title" as const, descKey: "why.industrial.description" as const },
    { num: "04", titleKey: "why.delivery.title" as const, descKey: "why.delivery.description" as const },
];
---

<section id="why-vandev" class="why-section py-24 relative scroll-mt-16">
    <div class="container mx-auto px-4 max-w-7xl">
        <!-- Section Header -->
        <div class="why-header mb-16">
            <div class="header-device-frame relative border border-lime-500/30 bg-black/60 p-8 max-w-2xl overflow-visible">
                <div class="absolute -top-[1px] -left-[1px] w-6 h-6 border-t-2 border-l-2 border-lime-400"></div>
                <div class="absolute -top-[1px] -right-[1px] w-6 h-6 border-t-2 border-r-2 border-lime-400"></div>
                <div class="absolute -bottom-[1px] -left-[1px] w-6 h-6 border-b-2 border-l-2 border-lime-400"></div>
                <div class="absolute -bottom-[1px] -right-[1px] w-6 h-6 border-b-2 border-r-2 border-lime-400"></div>

                <div class="header-tag font-mono text-xs text-lime-400 tracking-widest mb-4">
                    {t("why.tag")}
                </div>
                <h2 class="section-title text-5xl md:text-6xl lg:text-7xl font-black text-white leading-none">
                    {t("why.title.line1")}<br />
                    <span class="text-lime-400">{t("why.title.line2")}</span>
                </h2>
            </div>
        </div>

        <!-- Differentials Grid 2x2 -->
        <div class="why-grid grid grid-cols-1 md:grid-cols-2 gap-6">
            {differentials.map((item) => (
                <div class="why-card group relative border border-lime-500/15 bg-black/80 p-6 md:p-8 transition-all duration-400 hover:border-lime-500/50 hover:shadow-[0_20px_40px_-20px_rgba(191,255,0,0.15)]">
                    <!-- Corner Brackets -->
                    <div class="absolute -top-[1px] -left-[1px] w-5 h-5 border-t-2 border-l-2 border-lime-400/60 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>
                    <div class="absolute -top-[1px] -right-[1px] w-5 h-5 border-t-2 border-r-2 border-lime-400/60 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>
                    <div class="absolute -bottom-[1px] -left-[1px] w-5 h-5 border-b-2 border-l-2 border-lime-400/60 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>
                    <div class="absolute -bottom-[1px] -right-[1px] w-5 h-5 border-b-2 border-r-2 border-lime-400/60 pointer-events-none transition-all duration-300 group-hover:border-lime-400"></div>

                    <div class="flex items-start gap-5">
                        <span class="text-5xl md:text-6xl font-black text-lime-400/30 font-mono leading-none group-hover:text-lime-400/60 transition-colors select-none">
                            {item.num}
                        </span>
                        <div>
                            <h3 class="text-lg font-black text-white font-mono uppercase tracking-wide group-hover:text-lime-400 transition-colors">
                                {t(item.titleKey)}
                            </h3>
                            <p class="text-gray-400 text-sm font-mono mt-2 leading-relaxed">
                                &gt; {t(item.descKey)}
                            </p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // Header animation
        const headerFrame = document.querySelector("#why-vandev .header-device-frame");
        if (headerFrame) {
            gsap.set(headerFrame, { opacity: 0, x: -50 });
            gsap.to(headerFrame, {
                scrollTrigger: { trigger: "#why-vandev", start: "top 80%", toggleActions: "play none none none" },
                opacity: 1, x: 0, duration: 0.6, ease: "power3.out",
            });
        }

        // Cards stagger
        const cards = document.querySelectorAll(".why-card");
        cards.forEach((card, index) => {
            gsap.set(card, { opacity: 0, y: 40 });
            gsap.to(card, {
                scrollTrigger: { trigger: card, start: "top 90%", toggleActions: "play none none none" },
                opacity: 1, y: 0, duration: 0.6, delay: index * 0.1, ease: "power3.out",
            });
        });
    });
</script>
