<style>
    .background-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        z-index: -1;
        background-color: var(--color-surface);
    }

    /* Blueprint Grid - CSS only */
    .grid-blueprint {
        position: absolute;
        inset: 0;
        /* Grid lines */
        background-image:
            /* Vertical lines */
            repeating-linear-gradient(
                90deg,
                rgba(191, 255, 0, 0.04) 0px,
                rgba(191, 255, 0, 0.04) 1px,
                transparent 1px,
                transparent 80px
            ),
            /* Horizontal lines */
            repeating-linear-gradient(
                0deg,
                rgba(191, 255, 0, 0.04) 0px,
                rgba(191, 255, 0, 0.04) 1px,
                transparent 1px,
                transparent 80px
            ),
            /* Intersection dots - smaller grid overlay */
            radial-gradient(circle 1.5px at 0px 0px, rgba(191, 255, 0, 0.12) 1.5px, transparent 1.5px);
        background-size:
            80px 80px,
            80px 80px,
            80px 80px;
        /* Mask: radial fade from center */
        mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 100%);
        -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 100%);
    }

    /* Subtle center glow */
    .center-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(
            ellipse 50% 40% at 50% 45%,
            rgba(191, 255, 0, 0.03) 0%,
            transparent 100%
        );
    }

    /* Scrolling Terminal Logs */
    .terminal-logs {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: space-between;
        pointer-events: none;
        z-index: 0;
        opacity: 0.12;
        padding: 0 5%;
    }

    .log-column {
        flex: 1;
        overflow: hidden;
        font-family: monospace;
        font-size: 10px;
        line-height: 2.2;
        color: rgba(191, 255, 0, 0.25);
        white-space: nowrap;
        padding: 0 2rem;
        mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
        -webkit-mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
    }

    .log-entry { display: block; }

    /* Monochromatic lime palette */
    .log-ok { color: rgba(191, 255, 0, 0.5); }
    .log-tag { color: rgba(191, 255, 0, 0.35); }
    .log-cmd { color: rgba(191, 255, 0, 0.4); }
    .log-warn { color: rgba(191, 255, 0, 0.4); }
    .log-debug { color: rgba(191, 255, 0, 0.3); }
    .log-heading { color: rgba(255, 255, 255, 0.15); }
    .log-dim { color: rgba(255, 255, 255, 0.08); }

    .log-content {
        animation: scrollUp 60s linear infinite;
    }

    .log-col-1 .log-content { animation-duration: 55s; }
    .log-col-2 .log-content { animation-duration: 70s; animation-delay: -15s; }
    .log-col-3 .log-content { animation-duration: 80s; animation-delay: -30s; }

    @keyframes scrollUp {
        0% { transform: translateY(0); }
        100% { transform: translateY(-50%); }
    }

    /* Hide logs on small screens for cleaner mobile experience */
    @media (max-width: 768px) {
        .terminal-logs { display: none; }
    }
</style>
