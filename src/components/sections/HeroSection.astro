---
import "@styles/shared.css";
import type { Lang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";

interface Props {
    lang: Lang;
    vanRepoCount: number;
}

const { lang, vanRepoCount } = Astro.props;
const t = useTranslations(lang);
---

<section
    id="hero-section"
    class="hero-wrapper min-h-screen flex items-center justify-center pt-24 pb-8 px-4 md:px-8 relative overflow-hidden"
>
    <!-- Corner Decorative Texts -->
    <div class="corner-text corner-text-tl">
        <span class="font-mono text-[10px] text-gray-400 tracking-widest">CUSTOM SOFTWARE</span><br />
        <span class="font-mono text-[10px] text-gray-500">DEVELOPMENT</span>
    </div>
    <div class="corner-text corner-text-tr">
        <span class="font-mono text-[10px] text-gray-400 tracking-widest">WEB · DESKTOP ·</span><br />
        <span class="font-mono text-[10px] text-gray-500">SAAS · AI</span><br />
        <span class="font-mono text-[10px] text-lime-400">SOLUTIONS</span>
    </div>
    <div class="corner-text corner-text-bl">
        <span class="font-mono text-[10px] text-gray-500">BUILDING WITH</span><br />
        <span class="font-mono text-[10px] text-gray-400">RUST · REACT ·</span><br />
        <span class="font-mono text-[10px] text-lime-400">PYTHON</span>
    </div>
    <div class="corner-text corner-text-br">
        <span class="font-mono text-[10px] text-fuchsia-500">→ NUEVO LEÓN,</span><br />
        <span class="font-mono text-[10px] text-fuchsia-400 font-bold">MÉXICO</span>
    </div>

    <!-- Device Frame Container -->
    <div class="device-frame">
        <!-- Frame Corner Accents -->
        <div class="frame-corner top-left"></div>
        <div class="frame-corner top-right"></div>
        <div class="frame-corner bottom-left"></div>
        <div class="frame-corner bottom-right"></div>

        <!-- Inner Content -->
        <div class="device-content">
            <!-- Top Bar -->
            <div class="device-topbar">
                <span class="font-mono text-xs text-lime-400 tracking-wider">VANDEV</span>
                <div class="topbar-links">
                    <span class="text-gray-500 text-xs font-mono">/ GITHUB</span>
                    <span class="text-gray-500 text-xs font-mono">/ LINKEDIN</span>
                    <span class="text-gray-500 text-xs font-mono">/ CONTACT</span>
                </div>
            </div>

            <!-- Main Hero Content -->
            <div class="hero-content">
                <div class="hero-tag font-mono text-xs text-gray-500 tracking-widest uppercase mb-4">
                    {t("hero.tag")}
                </div>

                <!-- Massive Typography -->
                <h1 class="hero-massive">
                    <span class="sr-only">{lang === "es" ? "VanDev Studio — Desarrollo de Software a la Medida" : "VanDev Studio — Custom Software Development"}</span>
                    <span class="hero-line hero-line-1" aria-hidden="true">{t("hero.line1")}</span>
                    <span class="hero-line hero-line-2 text-lime-400" aria-hidden="true">{t("hero.line2")}</span>
                    <span class="hero-line hero-line-3" aria-hidden="true">{t("hero.line3")}</span>
                </h1>

                <p class="hero-tagline text-gray-400 text-sm md:text-base max-w-2xl mt-6 leading-relaxed font-mono">
                    {t("hero.tagline")}
                </p>

                <!-- CTA -->
                <div class="hero-cta mt-8 flex gap-4">
                    <a href="#services" class="btn-lime">
                        {t("hero.cta")}
                    </a>
                </div>
            </div>

            <!-- Bottom Info Bar -->
            <div class="device-bottombar">
                <div class="bottombar-item">
                    <span class="text-lime-400 font-bold">{vanRepoCount}+</span>
                    <span class="text-gray-400">{t("hero.stats.products")}</span>
                </div>
                <div class="bottombar-item">
                    <span class="text-lime-400 font-bold">4</span>
                    <span class="text-gray-400">{t("hero.stats.services")}</span>
                </div>
                <div class="bottombar-item">
                    <span class="text-lime-400 font-bold">2017</span>
                    <span class="text-gray-400">{t("hero.stats.since")}</span>
                </div>
                <div class="scroll-indicator">
                    <span class="text-gray-400 text-xs">SCROLL ↓</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Corner Decorative Texts */
    .corner-text {
        position: absolute;
        z-index: 5;
        line-height: 1.4;
        opacity: 0.8;
    }

    .corner-text-tl { top: 20px; left: 20px; text-align: left; }
    .corner-text-tr { top: 20px; right: 20px; text-align: right; }
    .corner-text-bl { bottom: 80px; left: 20px; text-align: left; }
    .corner-text-br { bottom: 30px; right: 30px; text-align: right; }

    @media (max-width: 768px) {
        .corner-text { display: none; }
    }

    /* Device Frame Container */
    .device-frame {
        position: relative;
        width: 100%;
        max-width: 1200px;
        background: var(--color-surface-glass);
        border: 1px solid rgba(191, 255, 0, 0.2);
        backdrop-filter: blur(8px);
        padding: 2px;
        z-index: 10;
    }

    .frame-corner {
        position: absolute;
        width: 24px;
        height: 24px;
        border: 2px solid var(--color-accent);
        z-index: 10;
    }
    .frame-corner.top-left { top: -2px; left: -2px; border-right: none; border-bottom: none; }
    .frame-corner.top-right { top: -2px; right: -2px; border-left: none; border-bottom: none; }
    .frame-corner.bottom-left { bottom: -2px; left: -2px; border-right: none; border-top: none; }
    .frame-corner.bottom-right { bottom: -2px; right: -2px; border-left: none; border-top: none; }

    .device-content { padding: 1.5rem 2rem; }

    /* Top Bar */
    .device-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(191, 255, 0, 0.1);
        margin-bottom: 2rem;
    }
    .topbar-links { display: flex; gap: 1.5rem; }

    /* Hero Content */
    .hero-content { text-align: left; }

    /* Massive Typography */
    .hero-massive {
        display: flex;
        flex-direction: column;
        line-height: 0.9;
    }

    .hero-line {
        font-size: clamp(3.5rem, 14vw, 10rem);
        font-weight: 900;
        letter-spacing: -0.05em;
        text-transform: uppercase;
    }

    .hero-line-1, .hero-line-3 {
        color: #fff;
        -webkit-text-stroke: 1px rgba(191, 255, 0, 0.3);
    }

    .hero-line-2 { position: relative; }
    .hero-line-3 { opacity: 0.6; }

    /* Button */
    .btn-lime {
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 1.5rem;
        background: var(--color-accent);
        color: #000;
        font-weight: 700;
        font-size: 0.75rem;
        font-family: monospace;
        letter-spacing: 0.1em;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-lime:hover {
        background: #a3e600;
        transform: translateY(-2px);
        box-shadow: 0 10px 40px rgba(191, 255, 0, 0.3);
    }

    /* Bottom Bar */
    .device-bottombar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(191, 255, 0, 0.1);
        margin-top: 2rem;
        font-family: monospace;
        font-size: 0.7rem;
    }
    .bottombar-item { display: flex; flex-direction: column; gap: 0.25rem; }
    .scroll-indicator { animation: bounce 2s infinite; }

    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
        40% { transform: translateY(-5px); }
        60% { transform: translateY(-3px); }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.set(
            [".device-frame", ".device-topbar", ".hero-line", ".hero-tag", ".hero-tagline", ".hero-cta", ".device-bottombar"],
            { opacity: 0 },
        );

        const tl = gsap.timeline({ defaults: { ease: "power4.out" }, delay: 0.3 });

        tl.to(".device-frame", { opacity: 1, duration: 0.8, scale: 1, ease: "power2.out" })
            .from(".device-frame", { scale: 0.95, duration: 0.8 }, "<")
            .to(".device-topbar", { opacity: 1, duration: 0.5 }, "-=0.3")
            .from(".device-topbar", { y: -20, duration: 0.5 }, "<")
            .to(".hero-line-1", { opacity: 1, duration: 0.6 }, "-=0.2")
            .from(".hero-line-1", { x: -100, duration: 0.6 }, "<")
            .to(".hero-line-2", { opacity: 1, duration: 0.6 }, "-=0.3")
            .from(".hero-line-2", { x: 100, duration: 0.6 }, "<")
            .to(".hero-line-3", { opacity: 0.6, duration: 0.6 }, "-=0.3")
            .from(".hero-line-3", { x: -50, duration: 0.6 }, "<")
            .to(".hero-tag", { opacity: 1, duration: 0.4 }, "-=0.4")
            .from(".hero-tag", { y: 20, duration: 0.4 }, "<")
            .to(".hero-tagline", { opacity: 1, duration: 0.4 }, "-=0.2")
            .from(".hero-tagline", { y: 20, duration: 0.4 }, "<")
            .to(".hero-cta", { opacity: 1, duration: 0.4 }, "-=0.1")
            .from(".hero-cta", { y: 20, duration: 0.4 }, "<")
            .to(".device-bottombar", { opacity: 1, duration: 0.4 }, "-=0.2")
            .from(".device-bottombar", { y: 20, duration: 0.4 }, "<");

        // Parallax on scroll
        gsap.to(".device-frame", {
            scrollTrigger: {
                trigger: "#hero-section",
                start: "top top",
                end: "bottom top",
                scrub: 1,
            },
            y: -50,
            scale: 0.98,
        });
    });
</script>
