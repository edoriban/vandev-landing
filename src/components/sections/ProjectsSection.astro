---
import "@styles/shared.css";
import type { Lang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";

interface Props {
    lang: Lang;
    vanRepoCount: number;
}

const { lang, vanRepoCount } = Astro.props;
const t = useTranslations(lang);

const projects = [
    {
        name: "VanERP",
        description: lang === "es"
            ? "Sistema ERP para control de ventas y cálculo de precios con márgenes porcentuales en cascada."
            : "ERP system for sales control and pricing with cascading percentage-based margins.",
        languages: ["TypeScript", "React", "Python", "SQLite"],
        repoUrl: "",
        challenge: lang === "es"
            ? "Motor de precios flexible con márgenes en cascada y consultas recursivas en SQLite para propagación de costos en tiempo real."
            : "Flexible pricing engine with cascading margins and recursive SQLite queries for real-time cost propagation.",
    },
    {
        name: "VanSkills",
        description: lang === "es"
            ? "Toolkit de habilidades para agentes IA — instrucciones especializadas que enseñan a asistentes IA a trabajar con frameworks y patrones específicos."
            : "AI agent skills toolkit — specialized instruction sets that teach AI assistants to work with specific frameworks and patterns.",
        languages: ["Python", "Markdown", "AI Agents"],
        repoUrl: "",
        challenge: lang === "es"
            ? "Arquitectura modular de skills que funciona entre diferentes runtimes de agentes IA con auto-sync de metadata."
            : "Modular skill architecture that works across different AI agent runtimes with auto-sync metadata.",
    },
    {
        name: "VanScript",
        description: lang === "es"
            ? "Descargador de transcripciones de YouTube y transcriptor local con GUI desktop. Pega URLs o selecciona archivos locales para transcribir con Whisper AI."
            : "YouTube transcript downloader and local file transcriber with modern desktop GUI. Paste URLs or select local files to transcribe with Whisper AI.",
        languages: ["Python", "CustomTkinter", "Whisper AI"],
        repoUrl: "",
        challenge: lang === "es"
            ? "Integración de faster-whisper con modelo bundled, procesamiento batch de múltiples URLs con manejo de fallos individuales y empaquetado como .exe con PyInstaller."
            : "Integration of faster-whisper with bundled model, batch processing of multiple URLs with individual failure handling, and .exe packaging with PyInstaller.",
    },
    {
        name: "VanFood",
        description: lang === "es"
            ? "Sistema de gestión de pedidos y delivery para restaurantes familiares. Multi-tenant, offline-first, con impresión térmica Bluetooth y sincronización en tiempo real."
            : "Order and delivery management system for family-owned restaurants. Multi-tenant, offline-first, with Bluetooth thermal printing and real-time sync.",
        languages: ["React Native", "Expo", "Supabase", "Zustand"],
        repoUrl: "",
        challenge: lang === "es"
            ? "Arquitectura offline-first con cola de operaciones y sync automático, aislamiento multi-tenant con RLS en Postgres, e impresión térmica ESC/POS vía Bluetooth."
            : "Offline-first architecture with operation queue and auto-sync, multi-tenant isolation with Postgres RLS, and ESC/POS thermal printing via Bluetooth.",
    },
];
---

<section id="projects" class="projects-section relative overflow-hidden py-24 scroll-mt-16">
    <div class="container mx-auto px-4 max-w-7xl">
        <!-- Section Header -->
        <div class="projects-header mb-16">
            <div class="header-device-frame relative border border-lime-500/30 bg-black/60 p-8 max-w-2xl overflow-visible">
                <div class="absolute -top-[1px] -left-[1px] w-6 h-6 border-t-2 border-l-2 border-lime-400"></div>
                <div class="absolute -top-[1px] -right-[1px] w-6 h-6 border-t-2 border-r-2 border-lime-400"></div>
                <div class="absolute -bottom-[1px] -left-[1px] w-6 h-6 border-b-2 border-l-2 border-lime-400"></div>
                <div class="absolute -bottom-[1px] -right-[1px] w-6 h-6 border-b-2 border-r-2 border-lime-400"></div>

                <div class="header-tag font-mono text-xs text-lime-400 tracking-widest mb-4">
                    {t("projects.tag")}
                </div>
                <h2 class="section-title text-5xl md:text-6xl lg:text-7xl font-black text-white leading-none">
                    {t("projects.title.line1")}<br />
                    <span class="text-lime-400">{t("projects.title.line2")}</span>
                </h2>
                <div class="header-status font-mono text-xs text-gray-500 mt-4 flex items-center gap-4">
                    <span class="flex items-center gap-2">
                        <span class="w-2 h-2 bg-lime-400 rounded-full animate-pulse"></span>
                        {t("projects.status")}
                    </span>
                    <span class="text-lime-500/50">|</span>
                    <span>COUNT: {projects.length}</span>
                </div>
            </div>
        </div>

        <!-- Counter Prominent -->
        <div class="counter-banner mb-12 flex items-center gap-4 font-mono">
            <span class="text-6xl md:text-8xl font-black text-lime-400">{vanRepoCount}+</span>
            <span class="text-xl md:text-2xl text-gray-400 uppercase tracking-wider">{t("projects.counter")}</span>
        </div>

        <!-- Projects Grid -->
        <div class="projects-grid grid grid-cols-1 md:grid-cols-2 gap-6">
            {projects.map((project, index) => (
                <article class="project-item group relative">
                    <!-- Corner Brackets -->
                    <div class="corner corner-tl"></div>
                    <div class="corner corner-tr"></div>
                    <div class="corner corner-bl"></div>
                    <div class="corner corner-br"></div>

                    <div class="project-card h-full flex flex-col relative overflow-hidden">
                        <!-- Top Bar -->
                        <div class="card-topbar flex items-center justify-between px-4 py-2 border-b border-lime-500/20 bg-black/80">
                            <div class="flex items-center gap-2 font-mono text-xs">
                                <span class="w-2 h-2 rounded-full bg-lime-400 animate-pulse"></span>
                                <span class="text-lime-400/70">PROJECT_{String(index + 1).padStart(2, '0')}</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                                <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                                <div class="w-2 h-2 rounded-full bg-lime-400"></div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="project-content flex-1 flex flex-col bg-black/80">
                            <div class="title-section px-4 py-3 border-b border-lime-500/10">
                                <h3 class="project-title text-lg font-black text-white group-hover:text-lime-400 transition-colors font-mono uppercase tracking-wide">
                                    {project.name}
                                </h3>
                            </div>

                            <div class="content-body px-4 py-4 flex-1 flex flex-col">
                                <p class="project-description text-gray-400 mb-3 flex-1 leading-relaxed text-sm font-mono">
                                    &gt; {project.description}
                                </p>

                                <p class="text-gray-500 mb-4 text-xs font-mono italic">
                                    // {project.challenge}
                                </p>

                                <!-- Technologies -->
                                <div class="project-languages flex flex-wrap gap-2 mb-4">
                                    {project.languages.map((lang) => (
                                        <span class="lang-chip font-mono text-[0.65rem] px-2 py-1 bg-lime-400/10 border border-lime-500/30 text-lime-400 uppercase tracking-wide">
                                            {lang}
                                        </span>
                                    ))}
                                </div>

                            </div>

                            <!-- Bottom Status -->
                            <div class="card-bottombar flex items-center justify-between px-4 py-2 border-t border-lime-500/10 bg-black/60">
                                <span class="font-mono text-xs text-gray-600">
                                    {project.languages.length} TECHNOLOGIES
                                </span>
                                <span class="font-mono text-xs text-lime-400/50">VAN* PRODUCT</span>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    /* Corner Brackets */
    .corner {
        position: absolute;
        width: 20px;
        height: 20px;
        z-index: 20;
        pointer-events: none;
        transition: all 0.3s ease;
    }
    .corner-tl { top: 0; left: 0; border-top: 2px solid rgba(191, 255, 0, 0.8); border-left: 2px solid rgba(191, 255, 0, 0.8); }
    .corner-tr { top: 0; right: 0; border-top: 2px solid rgba(191, 255, 0, 0.8); border-right: 2px solid rgba(191, 255, 0, 0.8); }
    .corner-bl { bottom: 0; left: 0; border-bottom: 2px solid rgba(191, 255, 0, 0.8); border-left: 2px solid rgba(191, 255, 0, 0.8); }
    .corner-br { bottom: 0; right: 0; border-bottom: 2px solid rgba(191, 255, 0, 0.8); border-right: 2px solid rgba(191, 255, 0, 0.8); }
    .project-item:hover .corner { border-color: var(--color-accent); }

    /* Project Card */
    .project-card {
        background: rgba(0, 0, 0, 0.8);
        border: 1px solid rgba(191, 255, 0, 0.15);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .project-card:hover {
        border-color: rgba(191, 255, 0, 0.5);
        transform: translateY(-8px);
        box-shadow: 0 20px 40px -20px rgba(191, 255, 0, 0.3);
    }

    /* Lang chip */
    .lang-chip { transition: all 0.2s ease; }
    .project-card:hover .lang-chip {
        background: rgba(191, 255, 0, 0.2);
        border-color: rgba(191, 255, 0, 0.5);
    }

    @media (max-width: 768px) {
        .projects-grid { grid-template-columns: 1fr; }
        .counter-banner span:first-child { font-size: 3rem; }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // Header animation
        const headerFrame = document.querySelector("#projects .header-device-frame");
        if (headerFrame) {
            gsap.set(headerFrame, { opacity: 0, x: -50 });
            gsap.to(headerFrame, {
                scrollTrigger: { trigger: "#projects", start: "top 80%", toggleActions: "play none none none" },
                opacity: 1, x: 0, duration: 0.6, ease: "power3.out",
            });
        }

        // Counter animation
        const counter = document.querySelector(".counter-banner");
        if (counter) {
            gsap.set(counter, { opacity: 0, y: 30 });
            gsap.to(counter, {
                scrollTrigger: { trigger: counter, start: "top 85%", toggleActions: "play none none none" },
                opacity: 1, y: 0, duration: 0.6, ease: "power3.out",
            });
        }

        // Project cards stagger
        const projectCards = document.querySelectorAll("#projects .project-item");
        projectCards.forEach((card, index) => {
            gsap.set(card, { opacity: 0, y: 50, scale: 0.95 });
            gsap.to(card, {
                scrollTrigger: { trigger: card, start: "top 90%", toggleActions: "play none none none" },
                opacity: 1, y: 0, scale: 1, duration: 0.6, delay: index * 0.1, ease: "power3.out",
            });
        });

        // 3D tilt
        projectCards.forEach((item) => {
            const card = item.querySelector(".project-card") as HTMLElement;
            if (!card) return;

            item.addEventListener("mousemove", (e: Event) => {
                const mouseEvent = e as MouseEvent;
                const rect = card.getBoundingClientRect();
                const x = mouseEvent.clientX - rect.left;
                const y = mouseEvent.clientY - rect.top;
                const rotateX = ((y - rect.height / 2) / (rect.height / 2)) * -3;
                const rotateY = ((x - rect.width / 2) / (rect.width / 2)) * 3;
                gsap.to(card, { rotateX, rotateY, scale: 1.02, duration: 0.3, ease: "power2.out", transformPerspective: 1000 });
            });

            item.addEventListener("mouseleave", () => {
                gsap.to(card, { rotateX: 0, rotateY: 0, scale: 1, duration: 0.5, ease: "power3.out" });
            });
        });
    });
</script>
