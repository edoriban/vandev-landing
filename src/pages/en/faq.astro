---
import LegalLayout from "@layouts/LegalLayout.astro";
import { useTranslations } from "@i18n/utils";

const lang = "en";
const t = useTranslations(lang);
const siteUrl = "https://vandev.mx";

const faqs = [
	{
		question: "What services does VanDev offer?",
		answer: "We offer web development (React, Next.js, Astro), desktop applications (Tauri + Rust), SaaS platforms, industrial AI solutions (computer vision, anomaly detection), and technology consulting.",
	},
	{
		question: "What technologies do you use?",
		answer: "Our main stack includes React, Next.js, Astro, and Tailwind for frontend; Rust and Tauri for desktop; Python, YOLO, and EfficientAD for AI; and Node.js, Django, and PostgreSQL for backend.",
	},
	{
		question: "What does the project process look like?",
		answer: "We start with a free consultation to understand your needs. Then we define scope and budget, followed by agile development with weekly incremental deliveries. You see real progress from week one.",
	},
	{
		question: "What is your pricing model?",
		answer: "We work with per-project budgets and also offer hourly contracts. Each proposal is tailored to the client's needs and budget. The initial consultation is free.",
	},
	{
		question: "How long does a typical project take?",
		answer: "It depends on scope: a website can be ready in 2-4 weeks, a web application in 1-3 months, and enterprise or AI solutions may take 3-6 months. We always provide a detailed timeline before starting.",
	},
	{
		question: "Do you offer post-launch support?",
		answer: "Yes. We offer ongoing maintenance and support plans. This includes bug fixes, security updates, performance optimization, and new features as needed.",
	},
	{
		question: "Do you work with clients outside México?",
		answer: "Yes, we work with clients from anywhere in the world. Communication is in Spanish or English, and we adapt to different time zones.",
	},
	{
		question: "How can I contact you?",
		answer: "Send us an email at edoriban@gmail.com or find us on GitHub and LinkedIn. We respond within 24 hours.",
	},
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
};
---

<LegalLayout
	title={t("legal.faq.title")}
	lang={lang}
	description="Frequently asked questions about VanDev. Services, technologies, project process, pricing, timelines, and support."
	canonicalUrl={`${siteUrl}/en/faq`}
	alternateUrl={`${siteUrl}/es/faq`}
	jsonLd={faqSchema}
>
	<div class="faq-list space-y-3">
		{faqs.map((faq, i) => (
			<details class="faq-item group border border-lime-500/20 bg-black/40">
				<summary class="flex items-center gap-3 cursor-pointer p-4 hover:bg-lime-400/5 transition-colors select-none">
					<span class="faq-chevron text-lime-400 text-xs font-mono transition-transform duration-200 group-open:rotate-90">&#9654;</span>
					<h3 class="text-gray-200 font-mono text-sm font-medium m-0">
						<span class="text-lime-400/60 mr-2">[{String(i).padStart(2, "0")}]</span>
						{faq.question}
					</h3>
				</summary>
				<div class="px-4 pb-4 pl-10">
					<p class="text-gray-400 font-mono text-sm leading-relaxed">{faq.answer}</p>
				</div>
			</details>
		))}
	</div>
</LegalLayout>

<style>
	details > summary::-webkit-details-marker {
		display: none;
	}

	details > summary {
		list-style: none;
	}

	.faq-item :global(h3) {
		font-size: 0.875rem;
		font-weight: 500;
		color: #e5e7eb;
		text-transform: none;
		letter-spacing: normal;
		margin: 0;
	}
</style>
