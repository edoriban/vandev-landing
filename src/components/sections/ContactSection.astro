---
import "@styles/shared.css";
import type { Lang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="contact-section py-24 relative scroll-mt-16">
    <div class="container mx-auto px-4 max-w-4xl">
        <!-- Device Frame Container -->
        <div class="contact-frame relative p-8 md:p-12 border border-lime-500/20 bg-black/40">
            <!-- Corner Accents -->
            <div class="absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-lime-400"></div>
            <div class="absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-lime-400"></div>
            <div class="absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-lime-400"></div>
            <div class="absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-lime-400"></div>

            <!-- Header -->
            <div class="contact-header text-center mb-8">
                <div class="header-tag font-mono text-xs text-lime-400 tracking-widest mb-4">
                    {t("contact.tag")}
                </div>
                <h2 class="section-title text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight">
                    {t("contact.title.line1")}<br />
                    <span class="text-lime-400">{t("contact.title.line2")}</span>
                </h2>
            </div>

            <!-- Description -->
            <p class="text-center text-gray-400 mb-6 text-base md:text-lg max-w-2xl mx-auto font-mono leading-relaxed">
                {t("contact.description.line1")}<br />
                {t("contact.description.line2")}<br />
                {t("contact.description.line3")}
            </p>

            <!-- Typing Terminal Prompt -->
            <div class="terminal-prompt text-center mb-8">
                <div class="inline-flex items-center gap-2 font-mono text-sm text-lime-400 bg-black/60 px-4 py-2 border border-lime-500/30">
                    <span class="text-gray-500">$</span>
                    <span id="typing-text" class="typing-text"></span>
                    <span class="typing-cursor w-2 h-4 bg-lime-400 animate-pulse"></span>
                </div>
            </div>

            <!-- CTA Button -->
            <div class="flex justify-center mb-8">
                <a
                    href="mailto:edoriban@gmail.com"
                    id="send-email-btn"
                    class="contact-btn group inline-flex items-center gap-3 font-mono text-sm px-8 py-4 bg-lime-400 text-black font-bold hover:bg-lime-300 transition-all duration-300 hover:shadow-[0_0_40px_rgba(191,255,0,0.4)] hover:-translate-y-1"
                >
                    <span class="w-2 h-2 bg-black animate-pulse"></span>
                    {t("contact.cta")}
                </a>
            </div>

            <!-- Social Links -->
            <div class="flex justify-center gap-4 mb-8">
                <a
                    href="https://github.com/edoriban"
                    target="_blank"
                    rel="noopener"
                    aria-label="GitHub"
                    class="social-link-contact w-10 h-10 flex items-center justify-center border border-lime-500/30 text-gray-400 hover:text-lime-400 hover:border-lime-400/60 hover:bg-lime-400/10 transition-all duration-300"
                >
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.207 11.387.6.113.793-.26.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.744.084-.729.084-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.236 1.911 1.236 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.824 1.102.824 2.222v3.293c0 .319.192.694.801.576C20.565 21.796 24 17.299 24 12c0-6.627-5.373-12-12-12z"></path>
                    </svg>
                </a>
                <a
                    href="https://www.linkedin.com/in/edoriban"
                    target="_blank"
                    rel="noopener"
                    aria-label="LinkedIn"
                    class="social-link-contact w-10 h-10 flex items-center justify-center border border-lime-500/30 text-gray-400 hover:text-lime-400 hover:border-lime-400/60 hover:bg-lime-400/10 transition-all duration-300"
                >
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
                    </svg>
                </a>
                <a
                    href="mailto:edoriban@gmail.com"
                    aria-label="Email"
                    class="social-link-contact w-10 h-10 flex items-center justify-center border border-lime-500/30 text-gray-400 hover:text-lime-400 hover:border-lime-400/60 hover:bg-lime-400/10 transition-all duration-300"
                >
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 13.065l-11.99-8.065h23.98l-11.99 8.065zm-12-7.065v14h24v-14l-12 8.065-12-8.065z"></path>
                    </svg>
                </a>
            </div>

            <!-- Status Line -->
            <div class="status-line flex justify-center items-center gap-4 font-mono text-xs text-gray-500">
                <span class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-lime-400 rounded-full animate-pulse"></span>
                    {t("contact.status")}
                </span>
                <span>|</span>
                <span>{t("contact.response")}</span>
                <span>|</span>
                <span>{t("contact.timezone")}</span>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-frame { position: relative; }
    .contact-frame:hover {
        border-color: rgba(191, 255, 0, 0.4);
        box-shadow: 0 0 60px rgba(191, 255, 0, 0.1);
    }
    .contact-btn {
        clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    }
    .social-link-contact {
        clip-path: polygon(0 4px, 4px 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0 100%);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const contactSection = document.querySelector("#contact");

        if (contactSection) {
            gsap.set(".contact-frame", { opacity: 0, scale: 0.95 });
            gsap.to(".contact-frame", {
                scrollTrigger: { trigger: "#contact", start: "top 80%", toggleActions: "play none none none" },
                opacity: 1, scale: 1, duration: 0.8, ease: "power2.out",
            });

            gsap.set(".contact-header .header-tag", { opacity: 0, y: 20 });
            gsap.set(".contact-header .section-title", { opacity: 0, y: 30 });

            gsap.to(".contact-header .header-tag", {
                scrollTrigger: { trigger: "#contact", start: "top 75%", toggleActions: "play none none none" },
                opacity: 1, y: 0, duration: 0.5, delay: 0.3,
            });

            gsap.to(".contact-header .section-title", {
                scrollTrigger: { trigger: "#contact", start: "top 75%", toggleActions: "play none none none" },
                opacity: 1, y: 0, duration: 0.6, delay: 0.5,
            });

            gsap.set(".contact-btn", { opacity: 0, y: 20 });
            gsap.to(".contact-btn", {
                scrollTrigger: { trigger: "#contact", start: "top 70%", toggleActions: "play none none none" },
                opacity: 1, y: 0, duration: 0.5, delay: 0.7,
            });

            // PowerGlitch effect on button hover
            import("powerglitch").then(({ PowerGlitch }) => {
                const btn = document.getElementById("send-email-btn");
                if (!btn) return;
                let glitchInstance: any = null;

                btn.addEventListener("mouseenter", () => {
                    if (!glitchInstance) {
                        glitchInstance = PowerGlitch.glitch(btn, {
                            playMode: "always", createContainers: true, hideOverflow: false,
                            timing: { duration: 250, iterations: 2 },
                            glitchTimeSpan: { start: 0, end: 1 },
                            shake: { velocity: 15, amplitudeX: 0.03, amplitudeY: 0.03 },
                            slice: { count: 3, velocity: 15, minHeight: 0.02, maxHeight: 0.15, hueRotate: true },
                        });
                    } else { glitchInstance.startGlitch(); }
                });

                btn.addEventListener("mouseleave", () => {
                    if (glitchInstance) glitchInstance.stopGlitch();
                });
            });
        }

        // Typing Terminal Prompt Animation
        const typingText = document.getElementById("typing-text");
        if (typingText) {
            const commands = [
                'vandev init --proyecto nuevo',
                'vandev deploy --produccion',
                'vandev test --cobertura 100',
                'cargo run --release producto',
                'docker compose up vandev',
            ];
            let commandIndex = 0;
            let charIndex = 0;
            let isDeleting = false;
            let hasStarted = false;

            const type = () => {
                const currentCommand = commands[commandIndex];

                if (isDeleting) {
                    typingText.textContent = currentCommand.substring(0, charIndex - 1);
                    charIndex--;
                    if (charIndex === 0) {
                        isDeleting = false;
                        commandIndex = (commandIndex + 1) % commands.length;
                        setTimeout(type, 500);
                        return;
                    }
                } else {
                    typingText.textContent = currentCommand.substring(0, charIndex + 1);
                    charIndex++;
                    if (charIndex === currentCommand.length) {
                        isDeleting = true;
                        setTimeout(type, 2000);
                        return;
                    }
                }
                setTimeout(type, isDeleting ? 30 : 70);
            };

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting && !hasStarted) {
                            hasStarted = true;
                            setTimeout(type, 500);
                        }
                    });
                },
                { threshold: 0.5 },
            );

            const contactEl = document.getElementById("contact");
            if (contactEl) observer.observe(contactEl);
        }
    });
</script>
