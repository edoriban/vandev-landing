---
import type { Lang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header
    id="main-header"
    class="header-main fixed top-0 left-0 right-0 z-50 flex justify-center py-3 transition-all duration-300 ease-in-out"
    style="will-change: transform, opacity;"
>
    <div
        class="header-content flex justify-between items-center w-full max-w-[1120px] px-4"
    >
        <a
            href={`/${lang}`}
            aria-label="Go to homepage"
            class="header-logo group"
            id="logo-container"
        >
            <div
                class="logo-frame relative px-3 py-1.5 border border-lime-500/40 bg-black/60 hover:border-lime-400 transition-all duration-300"
            >
                <!-- Mini Corner Brackets -->
                <div class="absolute -top-[1px] -left-[1px] w-2 h-2 border-t border-l border-lime-400"></div>
                <div class="absolute -top-[1px] -right-[1px] w-2 h-2 border-t border-r border-lime-400"></div>
                <div class="absolute -bottom-[1px] -left-[1px] w-2 h-2 border-b border-l border-lime-400"></div>
                <div class="absolute -bottom-[1px] -right-[1px] w-2 h-2 border-b border-r border-lime-400"></div>

                <div class="flex items-center gap-2">
                    <span class="text-lime-400 font-mono text-xs opacity-60">&gt;_</span>
                    <span class="logo-text font-mono font-bold text-sm tracking-wider text-white uppercase">
                        VAN<span class="text-lime-400">.DEV</span>
                    </span>
                </div>
            </div>
        </a>

        <!-- Desktop Navigation -->
        <nav
            id="main-nav"
            class="header-nav hidden md:flex flex-row gap-x-8 text-sm font-medium items-center"
        >
            <a href="#home" class="nav-link text-gray-300 hover:text-white transition-colors duration-200">
                {t("nav.home")}
            </a>
            <a href="#services" class="nav-link text-gray-300 hover:text-white transition-colors duration-200">
                {t("nav.services")}
            </a>
            <a href="#projects" class="nav-link text-gray-300 hover:text-white transition-colors duration-200">
                {t("nav.projects")}
            </a>
            <a href="#why-vandev" class="nav-link text-gray-300 hover:text-white transition-colors duration-200">
                {t("nav.why")}
            </a>
            <a href="#contact" class="nav-link text-gray-300 hover:text-white transition-colors duration-200">
                {t("nav.contact")}
            </a>
            <div class="ml-4">
                <LanguageSwitcher lang={lang} />
            </div>
        </nav>

        <!-- Mobile Navigation -->
        <div class="md:hidden flex items-center gap-3">
            <!-- Mobile Language Switcher -->
            <LanguageSwitcher lang={lang} />

            <!-- Hamburger Menu Button -->
            <button
                id="mobile-menu-btn"
                class="mobile-menu-btn flex items-center justify-center w-10 h-10 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 transition-all duration-300 text-white"
                aria-label="Toggle mobile menu"
                aria-expanded="false"
            >
                <svg
                    id="hamburger-icon"
                    class="w-6 h-6 transition-transform duration-300"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg
                    id="close-icon"
                    class="w-6 h-6 transition-transform duration-300 hidden"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile Menu Dropdown -->
    <div
        id="mobile-menu"
        class="mobile-menu md:hidden absolute top-full left-0 right-0 bg-[#020617]/95 backdrop-blur-xl border-b border-lime-500/20 shadow-2xl transform -translate-y-full opacity-0 pointer-events-none transition-all duration-300 ease-in-out z-40"
    >
        <nav class="flex flex-col py-6 px-6 space-y-2">
            <a href="#home" class="mobile-nav-link text-gray-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime-500/10 transition-all duration-300">
                {t("nav.home")}
            </a>
            <a href="#services" class="mobile-nav-link text-gray-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime-500/10 transition-all duration-300">
                {t("nav.services")}
            </a>
            <a href="#projects" class="mobile-nav-link text-gray-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime-500/10 transition-all duration-300">
                {t("nav.projects")}
            </a>
            <a href="#why-vandev" class="mobile-nav-link text-gray-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime-500/10 transition-all duration-300">
                {t("nav.why")}
            </a>
            <a href="#contact" class="mobile-nav-link text-gray-300 hover:text-white py-3 px-4 rounded-lg hover:bg-lime-500/10 transition-all duration-300">
                {t("nav.contact")}
            </a>
        </nav>
    </div>
</header>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            ".header-logo",
            { x: -100, opacity: 0 },
            { x: 0, opacity: 1, duration: 0.8, delay: 0.2, ease: "power2.out" },
        );

        gsap.fromTo(
            ".nav-link",
            { y: -20, opacity: 0 },
            {
                y: 0,
                opacity: 1,
                duration: 0.6,
                stagger: 0.1,
                delay: 0.4,
                ease: "power2.out",
            },
        );

        gsap.fromTo(
            ".lang-switcher",
            { scale: 0.8, opacity: 0 },
            {
                scale: 1,
                opacity: 1,
                duration: 0.6,
                delay: 0.8,
                ease: "back.out(1.5)",
            },
        );

        gsap.fromTo(
            ".mobile-menu-btn",
            { scale: 0.8, opacity: 0 },
            {
                scale: 1,
                opacity: 1,
                duration: 0.6,
                delay: 0.9,
                ease: "back.out(1.5)",
            },
        );

        const navLinks = document.querySelectorAll(".nav-link");
        navLinks.forEach((link) => {
            link.addEventListener("mouseenter", () => {
                gsap.to(link, { y: -2, scale: 1.05, duration: 0.2 });
            });
            link.addEventListener("mouseleave", () => {
                gsap.to(link, { y: 0, scale: 1, duration: 0.2 });
            });
        });

        // Mobile Menu Toggle
        const mobileMenuBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const hamburgerIcon = document.getElementById("hamburger-icon");
        const closeIcon = document.getElementById("close-icon");
        let isMenuOpen = false;

        function toggleMobileMenu() {
            isMenuOpen = !isMenuOpen;

            if (isMenuOpen) {
                mobileMenu?.classList.remove("-translate-y-full", "opacity-0", "pointer-events-none");
                mobileMenu?.classList.add("translate-y-0", "opacity-100", "pointer-events-auto");
                hamburgerIcon?.classList.add("hidden");
                closeIcon?.classList.remove("hidden");
                mobileMenuBtn?.setAttribute("aria-expanded", "true");

                gsap.fromTo(
                    ".mobile-nav-link",
                    { x: -30, opacity: 0 },
                    { x: 0, opacity: 1, duration: 0.3, stagger: 0.1, ease: "power2.out" },
                );
            } else {
                mobileMenu?.classList.add("-translate-y-full", "opacity-0", "pointer-events-none");
                mobileMenu?.classList.remove("translate-y-0", "opacity-100", "pointer-events-auto");
                hamburgerIcon?.classList.remove("hidden");
                closeIcon?.classList.add("hidden");
                mobileMenuBtn?.setAttribute("aria-expanded", "false");
            }
        }

        mobileMenuBtn?.addEventListener("click", toggleMobileMenu);

        const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");
        mobileNavLinks.forEach((link) => {
            link.addEventListener("click", () => {
                if (isMenuOpen) toggleMobileMenu();
            });
        });

        document.addEventListener("click", (e) => {
            if (
                isMenuOpen &&
                !mobileMenu?.contains(e.target as Node) &&
                !mobileMenuBtn?.contains(e.target as Node)
            ) {
                toggleMobileMenu();
            }
        });
    });

    // Throttle para optimizar el scroll
    function throttle(fn: (...args: any[]) => void, wait: number) {
        let lastTime = 0;
        return (...args: any[]) => {
            const now = Date.now();
            if (now - lastTime >= wait) {
                lastTime = now;
                fn(...args);
            }
        };
    }

    const header = document.getElementById("main-header");
    const handleScroll = () => {
        if (header && window.scrollY > 50) {
            header.classList.add("header-scrolled");
        } else if (header) {
            header.classList.remove("header-scrolled");
        }
    };
    const throttledScroll = throttle(handleScroll, 100);

    let listenersAdded = false;
    function addListeners() {
        if (!listenersAdded) {
            document.addEventListener("scroll", throttledScroll, { passive: true });
            document.addEventListener("astro:page-load", handleScroll);
            listenersAdded = true;
        }
    }
    function removeListeners() {
        if (listenersAdded) {
            document.removeEventListener("scroll", throttledScroll);
            document.removeEventListener("astro:page-load", handleScroll);
            listenersAdded = false;
        }
    }

    if (header) {
        addListeners();
        handleScroll();
        window.addEventListener("beforeunload", removeListeners);
        window.addEventListener("astro:page-unload", removeListeners);
    }
</script>
