---
import "@styles/shared.css";
---

<section id="contact" class="contact-section py-24 relative">
    <div class="container mx-auto px-4 max-w-4xl">
        <!-- Device Frame Container -->
        <div
            class="contact-frame relative p-8 md:p-12 border border-lime-500/20 bg-black/40"
        >
            <!-- Corner Accents -->
            <div
                class="corner-tl absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-lime-400"
            >
            </div>
            <div
                class="corner-tr absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-lime-400"
            >
            </div>
            <div
                class="corner-bl absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-lime-400"
            >
            </div>
            <div
                class="corner-br absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-lime-400"
            >
            </div>

            <!-- Header -->
            <div class="contact-header text-center mb-8">
                <div
                    class="header-tag font-mono text-xs text-lime-400 tracking-widest mb-4"
                >
                    // CONTACT.INIT
                </div>
                <h1
                    class="section-title text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight"
                >
                    LET'S<br />
                    <span class="text-lime-400">CONNECT_</span>
                </h1>
            </div>

            <!-- Description -->
            <p
                class="text-center text-gray-400 mb-6 text-base md:text-lg max-w-2xl mx-auto font-mono leading-relaxed"
            >
                > Ready to collaborate on your next project?<br />
                > Open for opportunities and new challenges.<br />
                > Let's build something amazing together.
            </p>

            <!-- Typing Terminal Prompt -->
            <div class="terminal-prompt text-center mb-8">
                <div
                    class="inline-flex items-center gap-2 font-mono text-sm text-lime-400 bg-black/60 px-4 py-2 border border-lime-500/30"
                >
                    <span class="text-gray-500">$</span>
                    <span id="typing-text" class="typing-text"></span>
                    <span
                        class="typing-cursor w-2 h-4 bg-lime-400 animate-pulse"
                    ></span>
                </div>
            </div>

            <!-- CTA Button -->
            <div class="flex justify-center">
                <a
                    href="mailto:edoriban@gmail.com"
                    id="send-email-btn"
                    class="contact-btn group inline-flex items-center gap-3 font-mono text-sm px-8 py-4 bg-lime-400 text-black font-bold hover:bg-lime-300 transition-all duration-300 hover:shadow-[0_0_40px_rgba(191,255,0,0.4)] hover:-translate-y-1"
                >
                    <span class="w-2 h-2 bg-black animate-pulse"></span>
                    SEND MESSAGE →
                </a>
            </div>

            <!-- Status Line -->
            <div
                class="status-line mt-10 flex justify-center items-center gap-4 font-mono text-xs text-gray-500"
            >
                <span class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-lime-400 rounded-full animate-pulse"
                    ></span>
                    STATUS: AVAILABLE
                </span>
                <span>|</span>
                <span>RESPONSE: &lt;24H</span>
                <span>|</span>
                <span>TIMEZONE: CST</span>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-frame {
        position: relative;
    }

    .contact-frame:hover {
        border-color: rgba(191, 255, 0, 0.4);
        box-shadow: 0 0 60px rgba(191, 255, 0, 0.1);
    }

    .contact-btn {
        clip-path: polygon(
            0 0,
            calc(100% - 12px) 0,
            100% 12px,
            100% 100%,
            12px 100%,
            0 calc(100% - 12px)
        );
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const contactSection = document.querySelector("#contact");

        if (contactSection) {
            // Frame entrance
            gsap.set(".contact-frame", { opacity: 0, scale: 0.95 });
            gsap.to(".contact-frame", {
                scrollTrigger: {
                    trigger: "#contact",
                    start: "top 80%",
                    toggleActions: "play none none none",
                },
                opacity: 1,
                scale: 1,
                duration: 0.8,
                ease: "power2.out",
            });

            // Header stagger
            gsap.set(".contact-header .header-tag", { opacity: 0, y: 20 });
            gsap.set(".contact-header .section-title", { opacity: 0, y: 30 });

            gsap.to(".contact-header .header-tag", {
                scrollTrigger: {
                    trigger: "#contact",
                    start: "top 75%",
                    toggleActions: "play none none none",
                },
                opacity: 1,
                y: 0,
                duration: 0.5,
                delay: 0.3,
            });

            gsap.to(".contact-header .section-title", {
                scrollTrigger: {
                    trigger: "#contact",
                    start: "top 75%",
                    toggleActions: "play none none none",
                },
                opacity: 1,
                y: 0,
                duration: 0.6,
                delay: 0.5,
            });

            // Button entrance
            gsap.set(".contact-btn", { opacity: 0, y: 20 });
            gsap.to(".contact-btn", {
                scrollTrigger: {
                    trigger: "#contact",
                    start: "top 70%",
                    toggleActions: "play none none none",
                },
                opacity: 1,
                y: 0,
                duration: 0.5,
                delay: 0.7,
            });

            // PowerGlitch effect on button hover
            import("powerglitch").then(({ PowerGlitch }) => {
                const btn = document.getElementById("send-email-btn");
                if (!btn) return;

                let glitchInstance: any = null;

                btn.addEventListener("mouseenter", () => {
                    if (!glitchInstance) {
                        glitchInstance = PowerGlitch.glitch(btn, {
                            playMode: "always",
                            createContainers: true,
                            hideOverflow: false,
                            timing: {
                                duration: 250,
                                iterations: 2,
                            },
                            glitchTimeSpan: {
                                start: 0,
                                end: 1,
                            },
                            shake: {
                                velocity: 15,
                                amplitudeX: 0.03,
                                amplitudeY: 0.03,
                            },
                            slice: {
                                count: 3,
                                velocity: 15,
                                minHeight: 0.02,
                                maxHeight: 0.15,
                                hueRotate: true,
                            },
                        });
                    } else {
                        glitchInstance.startGlitch();
                    }
                });

                btn.addEventListener("mouseleave", () => {
                    if (glitchInstance) {
                        glitchInstance.stopGlitch();
                    }
                });
            });
        }

        // Typing Terminal Prompt Animation
        const typingText = document.getElementById("typing-text");
        if (typingText) {
            const commands = [
                'echo "Let\'s work together"',
                'git commit -m "new collaboration"',
                "pnpm run build-future",
                "cargo run --release dreams",
                "docker compose up success",
            ];
            let commandIndex = 0;
            let charIndex = 0;
            let isDeleting = false;
            let hasStarted = false;

            const type = () => {
                const currentCommand = commands[commandIndex];

                if (isDeleting) {
                    typingText.textContent = currentCommand.substring(
                        0,
                        charIndex - 1,
                    );
                    charIndex--;

                    if (charIndex === 0) {
                        isDeleting = false;
                        commandIndex = (commandIndex + 1) % commands.length;
                        setTimeout(type, 500);
                        return;
                    }
                } else {
                    typingText.textContent = currentCommand.substring(
                        0,
                        charIndex + 1,
                    );
                    charIndex++;

                    if (charIndex === currentCommand.length) {
                        isDeleting = true;
                        setTimeout(type, 2000); // Pause before deleting
                        return;
                    }
                }

                setTimeout(type, isDeleting ? 30 : 70);
            };

            // Start typing when contact section is in view
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting && !hasStarted) {
                            hasStarted = true;
                            setTimeout(type, 500);
                        }
                    });
                },
                { threshold: 0.5 },
            );

            const contactSection = document.getElementById("contact");
            if (contactSection) observer.observe(contactSection);
        }
    });
</script>
